<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The core makes Client-Server API calls over HTTPS. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".PigeonApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:usesCleartextTraffic="true">
        <!-- usesCleartextTraffic is for talking to a local dev homeserver over
             http:// (e.g. 10.0.2.2:8008 from the emulator). Production servers
             are https; tighten this to a network-security-config before release.
             allowBackup=false: the encrypted session store must not be included
             in cloud/adb backups. -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
